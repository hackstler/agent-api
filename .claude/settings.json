{
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(npm install *)",
      "Bash(npm test*)",
      "Bash(docker-compose *)",
      "Bash(docker *)",
      "Bash(podman *)",
      "Bash(npx drizzle-kit *)",
      "Bash(curl http://localhost:*)",
      "Bash(curl https://api.*)",
      "Bash(git *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(sudo *)",
      "Bash(chmod 777 *)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "npm test -- --reporter=verbose 2>&1 | tail -60"
          }
        ]
      }
    ]
  }
}
